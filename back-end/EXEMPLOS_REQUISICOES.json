{
  "info": {
    "name": "FalaDoutor API - Pacientes CRUD",
    "description": "Exemplos de requisições para o CRUD de Pacientes",
    "version": "1.0.0"
  },
  "baseUrl": "http://localhost:3000",
  "requests": [
    {
      "name": "Criar Paciente",
      "method": "POST",
      "url": "/pacientes",
      "description": "Cria um novo paciente no sistema",
      "body": {
        "nome": "João Silva",
        "cpf": "12345678901",
        "dataNascimento": "1990-05-15",
        "plano": 1
      }
    },
    {
      "name": "Criar Paciente - Exemplo 2",
      "method": "POST",
      "url": "/pacientes",
      "description": "Cria outro paciente com dados diferentes",
      "body": {
        "nome": "Maria Santos",
        "cpf": "98765432109",
        "dataNascimento": "1985-10-20",
        "plano": 2
      }
    },
    {
      "name": "Criar Paciente - Exemplo 3",
      "method": "POST",
      "url": "/pacientes",
      "description": "Cria um terceiro paciente",
      "body": {
        "nome": "Pedro Oliveira",
        "cpf": "11122233344",
        "dataNascimento": "1995-03-10",
        "plano": 3
      }
    },
    {
      "name": "Listar Todos Pacientes",
      "method": "GET",
      "url": "/pacientes",
      "description": "Lista todos os pacientes (página 1, 10 itens por página)"
    },
    {
      "name": "Listar Pacientes - Página 1, 5 itens",
      "method": "GET",
      "url": "/pacientes?pagina=1&limite=5",
      "description": "Lista pacientes com paginação customizada"
    },
    {
      "name": "Buscar Paciente por ID",
      "method": "GET",
      "url": "/pacientes/1",
      "description": "Busca um paciente específico pelo ID"
    },
    {
      "name": "Buscar Paciente ID - Exemplo 2",
      "method": "GET",
      "url": "/pacientes/2",
      "description": "Busca o paciente com ID 2"
    },
    {
      "name": "Buscar Paciente ID - Exemplo 3",
      "method": "GET",
      "url": "/pacientes/3",
      "description": "Busca o paciente com ID 3"
    },
    {
      "name": "Atualizar Paciente",
      "method": "PUT",
      "url": "/pacientes/1",
      "description": "Atualiza os dados de um paciente (ID 1)",
      "body": {
        "nome": "João Silva Atualizado",
        "plano": 2
      }
    },
    {
      "name": "Atualizar Paciente - Todos os campos",
      "method": "PUT",
      "url": "/pacientes/1",
      "description": "Atualiza todos os campos de um paciente",
      "body": {
        "nome": "João Silva Novo Nome",
        "cpf": "12345678901",
        "dataNascimento": "1990-05-15",
        "plano": 3
      }
    },
    {
      "name": "Atualizar Apenas Plano",
      "method": "PUT",
      "url": "/pacientes/2",
      "description": "Atualiza apenas o plano de um paciente",
      "body": {
        "plano": 1
      }
    },
    {
      "name": "Deletar Paciente",
      "method": "DELETE",
      "url": "/pacientes/1",
      "description": "Deleta um paciente pelo ID"
    },
    {
      "name": "Deletar Paciente - ID 2",
      "method": "DELETE",
      "url": "/pacientes/2",
      "description": "Deleta o paciente com ID 2"
    },
    {
      "name": "Erro - CPF Duplicado",
      "method": "POST",
      "url": "/pacientes",
      "description": "Tentativa de criar paciente com CPF que já existe (vai falhar)",
      "body": {
        "nome": "Pessoa com CPF duplicado",
        "cpf": "12345678901",
        "dataNascimento": "1980-01-01",
        "plano": 1
      }
    },
    {
      "name": "Erro - Dados Inválidos",
      "method": "POST",
      "url": "/pacientes",
      "description": "Tentativa de criar paciente com dados inválidos (vai falhar)",
      "body": {
        "nome": "",
        "cpf": "123",
        "dataNascimento": "invalid",
        "plano": 5
      }
    },
    {
      "name": "Erro - ID não existe",
      "method": "GET",
      "url": "/pacientes/9999",
      "description": "Tentativa de buscar paciente com ID que não existe (vai falhar)"
    }
  ],
  "notes": {
    "planos": {
      "1": "Plano Bronze (básico)",
      "2": "Plano Prata (intermediário)",
      "3": "Plano Ouro (premium)"
    },
    "validacoes": {
      "nome": "Obrigatório, máximo 255 caracteres",
      "cpf": "Obrigatório, exatamente 11 dígitos, deve ser único",
      "dataNascimento": "Data válida (YYYY-MM-DD)",
      "plano": "Deve ser 1, 2 ou 3"
    },
    "status_codes": {
      "200": "OK - Requisição bem sucedida",
      "201": "Created - Recurso criado",
      "400": "Bad Request - Dados inválidos",
      "404": "Not Found - Recurso não encontrado",
      "500": "Server Error - Erro no servidor"
    }
  }
}
